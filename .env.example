# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# URL pública del backend (se usa para construir URLs absolutas de imágenes)
API_BASE_URL=http://localhost:3000

# ── Base de datos (MySQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=recetario

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ── Cookie ────────────────────────────────────────────────
COOKIE_SECRET=otro_secreto_para_las_cookies
COOKIE_MAX_AGE_MS=604800000

# ── CORS ──────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Subida de imágenes ────────────────────────────────────
UPLOADS_DIR=uploads
MAX_FILE_SIZE_MB=5
